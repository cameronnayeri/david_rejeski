---
import { CATEGORIES, STATUSES, type Project } from '../lib/db';

export interface Props {
  project?: Project;
}
const { project } = Astro.props;
const isEdit = !!project;
const data = project ?? null;
---

<form id="project-form" data-id={project?.id ?? ''}>
  <div id="msg" class="msg msg-error" hidden></div>

  <div class="field">
    <label for="title">Title</label>
    <input type="text" id="title" name="title" required value={data?.title ?? ''} />
  </div>

  <div class="row">
    <div class="field">
      <label for="category">Category</label>
      <select id="category" name="category">
        {CATEGORIES.map((c) => (
          <option value={c} selected={data?.category === c}>{c}</option>
        ))}
      </select>
    </div>
    <div class="field">
      <label for="year">Year</label>
      <input type="number" id="year" name="year" value={data?.year ?? ''} />
    </div>
    <div class="field">
      <label for="number">Display #</label>
      <input type="number" id="number" name="number" value={data?.number ?? ''} />
    </div>
  </div>

  <div class="field">
    <label for="materials">Materials and Dimensions</label>
    <textarea id="materials" name="materials" placeholder="One per line">{(data?.materials ?? []).join('\n')}</textarea>
    <p class="hint">One material or dimension per line.</p>
  </div>

  <div class="field">
    <label for="description">Description</label>
    <textarea id="description" name="description">{data?.description ?? ''}</textarea>
  </div>

  <div class="field">
    <label for="caption">Caption</label>
    <textarea id="caption" name="caption">{data?.caption ?? ''}</textarea>
    <p class="hint">Optional italic note shown under the description.</p>
  </div>

  <!-- ── Images ─────────────────────────────── -->
  <div class="field">
    <label>Images</label>
    <div id="dropzone" class="dropzone">
      <p>Drag &amp; drop images here, or</p>
      <div class="dz-buttons">
        <button type="button" class="btn btn-secondary" id="pick-files">Choose files</button>
        <button type="button" class="btn btn-secondary" id="pick-library">Pick from library</button>
      </div>
      <input type="file" id="file-input" accept="image/*" multiple hidden />
    </div>
    <ul id="image-list" class="image-list"></ul>
    <p class="hint">Drag thumbnails to reorder. The first image is the cover.</p>
  </div>

  <div class="row">
    <div class="field" style="flex:0 0 auto">
      <label for="status">Status</label>
      <select id="status" name="status">
        {STATUSES.map((s) => (
          <option value={s} selected={data?.status === s}>{s}</option>
        ))}
      </select>
    </div>
  </div>

  <div class="form-actions">
    <button type="submit" class="btn" id="save-btn">{isEdit ? 'Save changes' : 'Create project'}</button>
    <a href="/admin/dashboard" class="btn btn-secondary">Cancel</a>
    {isEdit && (
      <button type="button" class="btn-trash" id="delete-btn" style="margin-left:auto" aria-label="Delete project" title="Delete">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2m2 0v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
      </button>
    )}
  </div>
</form>

<!-- Library picker modal -->
<div id="library-modal" class="modal" hidden>
  <div class="modal-box">
    <div class="modal-head">
      <strong>Image library</strong>
      <button type="button" class="admin-link" id="lib-close">Close</button>
    </div>
    <div id="lib-grid" class="lib-grid"><p class="lib-loading">Loading…</p></div>
  </div>
</div>

<script is:inline define:vars={{ initialImages: data?.images ?? [], slugBase: data?.slug ?? '' }}>
  (function () {
    const form = document.getElementById('project-form');
    const id = form.dataset.id;
    const msg = document.getElementById('msg');
    const listEl = document.getElementById('image-list');
    const fileInput = document.getElementById('file-input');
    const dropzone = document.getElementById('dropzone');
    let images = [...initialImages];

    // slug guess used to group uploads in R2 (server makes the final slug)
    function currentSlug() {
      const t = document.getElementById('title').value || slugBase || 'project';
      return t.toLowerCase().trim().replace(/['"]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }

    function render() {
      listEl.innerHTML = '';
      images.forEach((url, i) => {
        const li = document.createElement('li');
        li.className = 'image-item';
        li.draggable = true;
        li.dataset.index = String(i);
        li.innerHTML =
          `<span class="img-handle" title="Drag to reorder">⠿</span>` +
          `<img src="${url}" alt="" />` +
          `<button type="button" class="img-remove" title="Remove">×</button>`;
        li.querySelector('.img-remove').addEventListener('click', () => {
          images.splice(i, 1); render();
        });
        addDragHandlers(li);
        listEl.appendChild(li);
      });
    }

    let dragFrom = null;
    function addDragHandlers(li) {
      li.addEventListener('dragstart', () => { dragFrom = +li.dataset.index; li.classList.add('dragging'); });
      li.addEventListener('dragend', () => li.classList.remove('dragging'));
      li.addEventListener('dragover', (e) => e.preventDefault());
      li.addEventListener('drop', (e) => {
        e.preventDefault();
        const to = +li.dataset.index;
        if (dragFrom === null || dragFrom === to) return;
        const [moved] = images.splice(dragFrom, 1);
        images.splice(to, 0, moved);
        dragFrom = null; render();
      });
    }

    async function uploadFiles(files) {
      for (const file of files) {
        if (!file.type.startsWith('image/')) continue;
        const fd = new FormData();
        fd.append('file', file);
        fd.append('slug', currentSlug());
        const res = await fetch('/api/upload', { method: 'POST', body: fd });
        const out = await res.json();
        if (out.ok) { images.push(out.url); render(); }
        else { showError(out.error || 'Upload failed.'); }
      }
    }

    function showError(text) { msg.className = 'msg msg-error'; msg.textContent = text; msg.hidden = false; }

    // file picker
    document.getElementById('pick-files').addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => uploadFiles([...fileInput.files]));

    // drag & drop
    ['dragenter', 'dragover'].forEach((ev) =>
      dropzone.addEventListener(ev, (e) => { e.preventDefault(); dropzone.classList.add('over'); }));
    ['dragleave', 'drop'].forEach((ev) =>
      dropzone.addEventListener(ev, (e) => { e.preventDefault(); dropzone.classList.remove('over'); }));
    dropzone.addEventListener('drop', (e) => uploadFiles([...e.dataTransfer.files]));

    // library
    const modal = document.getElementById('library-modal');
    const grid = document.getElementById('lib-grid');
    document.getElementById('pick-library').addEventListener('click', async () => {
      modal.hidden = false;
      grid.innerHTML = '<p class="lib-loading">Loading…</p>';
      const res = await fetch('/api/library');
      const { images: lib } = await res.json();
      if (!lib.length) { grid.innerHTML = '<p class="lib-loading">No images uploaded yet.</p>'; return; }
      grid.innerHTML = '';
      lib.forEach((img) => {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'lib-thumb';
        b.innerHTML = `<img src="${img.url}" alt="" loading="lazy" />`;
        b.addEventListener('click', () => {
          if (!images.includes(img.url)) { images.push(img.url); render(); }
          modal.hidden = true;
        });
        grid.appendChild(b);
      });
    });
    document.getElementById('lib-close').addEventListener('click', () => (modal.hidden = true));
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.hidden = true; });

    // delete
    const delBtn = document.getElementById('delete-btn');
    if (delBtn) {
      delBtn.addEventListener('click', async () => {
        if (!confirm('Delete this project? This cannot be undone.')) return;
        const res = await fetch(`/api/projects/${id}`, { method: 'DELETE' });
        if (res.ok) window.location.href = '/admin/dashboard';
        else showError('Delete failed.');
      });
    }

    // submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.hidden = true;
      const saveBtn = document.getElementById('save-btn');
      saveBtn.disabled = true;
      const payload = {
        title: document.getElementById('title').value,
        category: document.getElementById('category').value,
        year: document.getElementById('year').value,
        number: document.getElementById('number').value,
        materials: document.getElementById('materials').value.split('\n').map((s) => s.trim()).filter(Boolean),
        description: document.getElementById('description').value,
        caption: document.getElementById('caption').value,
        status: document.getElementById('status').value,
        images,
      };
      const url = id ? `/api/projects/${id}` : '/api/projects';
      const method = id ? 'PUT' : 'POST';
      const res = await fetch(url, {
        method,
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const out = await res.json();
      if (out.ok) window.location.href = '/admin/dashboard';
      else { showError(out.error || 'Save failed.'); saveBtn.disabled = false; }
    });

    render();
  })();
</script>

<style>
  .dropzone {
    border: 2px dashed var(--divider); border-radius: 8px; padding: 1.5rem; text-align: center;
    background: var(--field); transition: border-color 0.15s, background 0.15s;
  }
  .dropzone.over { border-color: var(--accent); background: #f6ece6; }
  .dropzone p { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.75rem; }
  .dz-buttons { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; }

  .image-list { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.9rem; }
  /* Thumbnails are created in JS, so they don't get Astro's scope attribute —
     these rules are :global, anchored to the #image-list container. */
  #image-list :global(.image-item) {
    position: relative; width: 72px; height: 72px; border-radius: 6px; overflow: hidden;
    background: #ECEAE0; cursor: grab; border: 1px solid var(--divider);
  }
  #image-list :global(.image-item:active) { cursor: grabbing; }
  #image-list :global(.image-item.dragging) { opacity: 0.4; }
  #image-list :global(.image-item img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  #image-list :global(.img-handle) {
    position: absolute; top: 0; left: 0; right: 0; height: 16px; display: flex;
    align-items: center; justify-content: center; font-size: 0.7rem; line-height: 1;
    color: #fff; background: rgba(0,0,0,0.45); letter-spacing: 1px; pointer-events: none;
  }
  #image-list :global(.img-remove) {
    position: absolute; top: 2px; right: 2px; width: 18px; height: 18px; border-radius: 50%;
    border: none; background: rgba(0,0,0,0.65); color: #fff; cursor: pointer; line-height: 1;
    font-size: 0.8rem; z-index: 2;
  }
  #image-list :global(.image-item:first-child::after) {
    content: 'cover'; position: absolute; bottom: 0; left: 0; right: 0; text-align: center;
    font-size: 0.55rem; background: var(--accent); color: #fff; padding: 1px;
  }

  .form-actions { display: flex; align-items: center; gap: 0.8rem; margin-top: 1.5rem; }

  .modal {
    position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex;
    align-items: center; justify-content: center; z-index: 100; padding: 1rem;
  }
  .modal[hidden] { display: none; }
  .modal-box {
    background: var(--bg); border-radius: 10px; width: 100%; max-width: 720px;
    max-height: 80vh; display: flex; flex-direction: column; overflow: hidden;
  }
  .modal-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--divider);
  }
  .lib-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(96px, 1fr));
    grid-auto-rows: 96px; gap: 0.6rem; padding: 1rem 1.25rem; overflow-y: auto;
  }
  /* Library thumbs are also JS-created — :global, anchored to #lib-grid. */
  #lib-grid :global(.lib-loading) { color: var(--muted); grid-column: 1 / -1; }
  #lib-grid :global(.lib-thumb) {
    display: block; height: 96px; width: 100%; padding: 0; margin: 0;
    border: 1px solid var(--divider); border-radius: 6px; overflow: hidden;
    cursor: pointer; background: #ECEAE0;
  }
  #lib-grid :global(.lib-thumb:hover) { outline: 2px solid var(--accent); }
  #lib-grid :global(.lib-thumb img) { width: 100%; height: 100%; object-fit: cover; display: block; }
</style>
