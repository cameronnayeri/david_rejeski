---
export interface Props {
  data: {
    title: string;
    number: number;
    year: number;
    category: string;
    materials: string[];
    description?: string;
    caption?: string;
    images: string[];
  };
  imageLayout?: 'grid' | 'masonry' | 'cover';
}

const { data, imageLayout = 'grid' } = Astro.props;
const materialsStr = data.materials.map((m) => m.toUpperCase()).join(' · ');
const PLACEHOLDER_COUNT = 6;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="piece">
  <header class="piece-header">
    <p class="meta-label">PROJECTS · {data.category.toUpperCase()} · {data.year}</p>
    <h1 class="piece-title">{data.title}</h1>
    <p class="piece-materials">{materialsStr}</p>
  </header>

  <hr class="divider" />

  <div class="text-col">
    {data.description && <p class="piece-description">{data.description}</p>}
    {data.caption && <p class="piece-caption">{data.caption}</p>}
  </div>

  <div class:list={['image-grid', { 'image-grid--masonry': imageLayout === 'masonry', 'image-grid--cover': imageLayout === 'cover' }]}>
    {data.images.length > 0
      ? data.images.map((src, i) => (
          <div class="image-cell">
            <img src={`${base}${src}`} alt={`${data.title}, view ${i + 1}`} />
          </div>
        ))
      : Array.from({ length: PLACEHOLDER_COUNT }).map((_, i) => (
          <div class="image-cell placeholder">
            <span class="placeholder-label">IMAGE {String(i + 1).padStart(2, '0')}</span>
          </div>
        ))
    }
  </div>
</article>

<style>
  /* ── Page offset ─────────────────────────────── */

  .piece {
    margin-left: 32%;
    padding: 2.5rem 3rem 7rem 2rem;
    display: grid;
    grid-template-columns: 26fr 74fr;
    column-gap: 3.5rem;
    row-gap: 0;
  }

  /* ── Header (right column) ───────────────────── */

  .piece-header {
    grid-column: 2;
    grid-row: 1;
    padding-bottom: 0;
    margin-bottom: 2rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .piece-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 0.75rem;
  }

  .piece-materials {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  /* ── Divider (right column only) ─────────────── */

  hr.divider {
    grid-column: 2;
    grid-row: 2;
    border: none;
    border-top: 1px solid var(--divider);
    margin: 0 0 2.5rem;
    width: 100%;
    display: block;
  }

  /* ── Text col (left, same row as images) ─────── */

  .text-col {
    grid-column: 1;
    grid-row: 3;
    align-self: start;
    padding-top: 0.25rem;
  }

  .piece-description {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .piece-caption {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--ink);
    opacity: 0.75;
  }

  /* ── Image grid (right col, uniform) ─────────── */

  .image-grid {
    grid-column: 2;
    grid-row: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.125rem;
  }

  .image-cell {
    aspect-ratio: 3 / 4;
    background: #ECEAE0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-cell img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .image-cell.placeholder {
    aspect-ratio: 3 / 4;
    background: #ECEAE0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    opacity: 0.5;
  }

  /* ── Masonry variant ─────────────────────────── */

  .image-grid--masonry {
    display: block;
    columns: 2;
    column-gap: 1.125rem;
  }

  .image-grid--masonry .image-cell {
    aspect-ratio: unset;
    break-inside: avoid;
    margin-bottom: 1.125rem;
    display: block;
  }

  .image-grid--masonry .image-cell img {
    width: 100%;
    height: auto;
    object-fit: unset;
  }

  /* ── Cover variant (uniform boxes, image fills/crops) ── */

  .image-grid--cover .image-cell img {
    object-fit: cover;
  }

  /* ── Responsive ──────────────────────────────── */

  @media (max-width: 900px) {
    .piece {
      margin-left: 0;
      padding: 1.5rem 1.5rem 5rem;
      display: block;
    }

    .piece-header {
      margin-bottom: 1.5rem;
    }

    .image-grid,
    .image-grid--masonry {
      columns: 1;
      grid-template-columns: 1fr;
    }
  }
</style>
