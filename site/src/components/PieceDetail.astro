---
export interface Props {
  data: {
    title: string;
    number: number;
    year: number;
    category: string;
    materials: string[];
    description?: string;
    caption?: string;
    images: string[];
  };
  imageLayout?: 'grid' | 'masonry' | 'masonry-3' | 'alternating' | 'cover';
}

const { data, imageLayout = 'grid' } = Astro.props;
const materialsStr = data.materials.map((m) => m.toUpperCase()).join(' · ');
const PLACEHOLDER_COUNT = 6;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="piece">
  <header class="piece-header">
    <p class="meta-label">PROJECTS · {data.category.toUpperCase()} · {data.year}</p>
    <h1 class="piece-title">{data.title}</h1>
    <p class="piece-materials">{materialsStr}</p>
  </header>

  <hr class="divider" />

  <div class="text-col">
    {data.description && <p class="piece-description">{data.description}</p>}
    {data.caption && <p class="piece-caption">{data.caption}</p>}
  </div>

  <div class:list={['image-grid', { 'image-grid--masonry': imageLayout === 'masonry', 'image-grid--masonry-3': imageLayout === 'masonry-3', 'image-grid--alternating': imageLayout === 'alternating', 'image-grid--cover': imageLayout === 'cover' }]}>
    {data.images.length > 0
      ? data.images.map((src, i) => (
          <div class="image-cell">
            <img src={`${base}${src}`} alt={`${data.title}, view ${i + 1}`} data-lightbox />
          </div>
        ))
      : Array.from({ length: PLACEHOLDER_COUNT }).map((_, i) => (
          <div class="image-cell placeholder">
            <span class="placeholder-label">IMAGE {String(i + 1).padStart(2, '0')}</span>
          </div>
        ))
    }
  </div>
</article>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" aria-modal="true" aria-label="Image viewer" hidden>
  <button class="lb-btn lb-close" id="lb-close" aria-label="Close">&#x2715;</button>
  <button class="lb-btn lb-prev" id="lb-prev" aria-label="Previous">&#x2190;</button>
  <div class="lb-stage" id="lb-stage">
    <img class="lb-img" id="lb-img" src="" alt="" />
  </div>
  <button class="lb-btn lb-next" id="lb-next" aria-label="Next">&#x2192;</button>
</div>

<style>
  /* ── Page offset ─────────────────────────────── */

  .piece {
    margin-left: 32%;
    padding: 2.5rem 3rem 7rem 2rem;
    display: grid;
    grid-template-columns: 26fr 74fr;
    column-gap: 3.5rem;
    row-gap: 0;
  }

  /* ── Header (right column) ───────────────────── */

  .piece-header {
    grid-column: 2;
    grid-row: 1;
    padding-bottom: 0;
    margin-bottom: 2rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .piece-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 0.75rem;
  }

  .piece-materials {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  /* ── Divider (right column only) ─────────────── */

  hr.divider {
    grid-column: 2;
    grid-row: 2;
    border: none;
    border-top: 1px solid var(--divider);
    margin: 0 0 2.5rem;
    width: 100%;
    display: block;
  }

  /* ── Text col (left, same row as images) ─────── */

  .text-col {
    grid-column: 1;
    grid-row: 3;
    align-self: start;
    padding-top: 0.25rem;
  }

  .piece-description {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .piece-caption {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--ink);
    opacity: 0.75;
  }

  /* ── Image grid (right col, uniform) ─────────── */

  .image-grid {
    grid-column: 2;
    grid-row: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.125rem;
  }

  .image-cell {
    aspect-ratio: 3 / 4;
    background: #ECEAE0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-cell img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    cursor: zoom-in;
  }

  .image-cell.placeholder {
    aspect-ratio: 3 / 4;
    background: #ECEAE0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    opacity: 0.5;
  }

  /* ── Masonry variant ─────────────────────────── */

  .image-grid--masonry {
    display: block;
    columns: 2;
    column-gap: 1.125rem;
  }

  .image-grid--masonry .image-cell {
    aspect-ratio: unset;
    break-inside: avoid;
    margin-bottom: 1.125rem;
    display: block;
  }

  .image-grid--masonry .image-cell img {
    width: 100%;
    height: auto;
    object-fit: unset;
  }

  /* ── Masonry 3-col variant ───────────────────── */

  .image-grid--masonry-3 {
    display: block;
    columns: 3;
    column-gap: 1.125rem;
  }

  .image-grid--masonry-3 .image-cell {
    aspect-ratio: unset;
    break-inside: avoid;
    margin-bottom: 1.125rem;
    display: block;
    background: none;
  }

  .image-grid--masonry-3 .image-cell img {
    width: 100%;
    height: auto;
    object-fit: unset;
  }

  /* ── Alternating variant ─────────────────────── */

  .image-grid--alternating {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.125rem;
  }

  .image-grid--alternating .image-cell {
    aspect-ratio: unset;
    background: none;
    overflow: visible;
  }

  .image-grid--alternating .image-cell img {
    width: 100%;
    height: auto;
    object-fit: unset;
    display: block;
  }

  .image-grid--alternating .image-cell:nth-child(3n+1) {
    grid-column: 1 / -1;
  }

  /* ── Cover variant ───────────────────────────── */

  .image-grid--cover .image-cell img {
    object-fit: cover;
  }

  /* ── Lightbox ────────────────────────────────── */

  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.94);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lb-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: calc(100vw - 10rem);
    max-height: 100vh;
    padding: 3rem 0;
  }

  .lb-img {
    max-width: 100%;
    max-height: calc(100vh - 6rem);
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
    cursor: default;
  }

  .lb-btn {
    position: fixed;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-display);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.75rem 1rem;
    transition: color 0.15s;
    line-height: 1;
    z-index: 1001;
  }

  .lb-btn:hover {
    color: #fff;
  }

  .lb-close {
    top: 1.25rem;
    right: 1.5rem;
    font-size: 1rem;
  }

  .lb-prev {
    left: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
  }

  .lb-next {
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
  }

  /* ── Responsive ──────────────────────────────── */

  @media (max-width: 900px) {
    .piece {
      margin-left: 0;
      padding: 1.5rem 1.5rem 5rem;
      display: block;
    }

    .piece-header {
      margin-bottom: 1.5rem;
    }

    .image-grid,
    .image-grid--masonry {
      columns: 1;
      grid-template-columns: 1fr;
    }

    .lb-stage {
      max-width: 100vw;
      padding: 4rem 1rem;
    }

    .lb-prev { left: 0.25rem; }
    .lb-next { right: 0.25rem; }
  }
</style>

<script>
  const images = [...document.querySelectorAll<HTMLImageElement>('[data-lightbox]')];
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbPrev = document.getElementById('lb-prev')!;
  const lbNext = document.getElementById('lb-next')!;
  let current = 0;

  function show(index: number) {
    current = (index + images.length) % images.length;
    lbImg.src = images[current].src;
    lbImg.alt = images[current].alt;
    lbPrev.style.visibility = images.length > 1 ? 'visible' : 'hidden';
    lbNext.style.visibility = images.length > 1 ? 'visible' : 'hidden';
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  images.forEach((img, i) => img.addEventListener('click', () => show(i)));

  document.getElementById('lb-close')!.addEventListener('click', close);
  lbPrev.addEventListener('click', () => show(current - 1));
  lbNext.addEventListener('click', () => show(current + 1));

  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });

  document.addEventListener('keydown', (e) => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>
