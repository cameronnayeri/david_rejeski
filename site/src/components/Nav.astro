---
export interface Props {
  active?: 'home' | 'projects' | 'sketch-object' | 'sketches' | 'studio';
}
const { active } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<a href={`${base}/`} class="site-wordmark">David Rejeski</a>

<nav class="site-nav" id="siteNav">
  <a href={`${base}/`} class="nav-brand">David Rejeski</a>

  <button class="menu-btn" id="menuBtn" aria-label="Open menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <ul class="nav-links">
    <li><a href={`${base}/`}              class:list={['nav-link', { active: active === 'home' }]}>Home</a></li>
    <li><a href={`${base}/projects`}      class:list={['nav-link', { active: active === 'projects' }]}>Projects</a></li>
    <li>
      <a href={`${base}/sketch-object`}   class:list={['nav-link', { active: active === 'sketch-object' }]}>
        2D<span class="bar">|</span>3D
      </a>
    </li>
    <li><a href={`${base}/sketches`}      class:list={['nav-link', { active: active === 'sketches' }]}>Sketches</a></li>
    <li><a href={`${base}/studio`}        class:list={['nav-link', { active: active === 'studio' }]}>Studio</a></li>
  </ul>

  <ul class="nav-right">
    <li><a href="mailto:dave.rejeski@gmail.com" class="nav-link">Email</a></li>
  </ul>
</nav>

<style>
  .site-wordmark {
    display: block;
    padding: 1.5rem 3rem 0;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--ink);
    text-decoration: none;
  }

  .site-wordmark:hover { opacity: 0.6; }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 3rem 1.35rem;
  }

  .nav-brand { display: none; }
  .menu-btn  { display: none; }

  .nav-links,
  .nav-right {
    display: flex;
    gap: 2rem;
    list-style: none;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: 0.01em;
    transition: opacity 0.15s;
  }

  .nav-link:hover { opacity: 0.55; }

  .nav-link.active {
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1.5px;
  }

  .bar {
    color: var(--accent);
    margin: 0 1px;
  }

  /* ── Mobile ─────────────────────────────────────── */

  @media (max-width: 700px) {
    .site-wordmark { display: none; }

    .site-nav {
      padding: 1.25rem 1.5rem;
      flex-wrap: wrap;
    }

    .nav-brand {
      display: block;
      font-family: var(--font-display);
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.01em;
      color: var(--ink);
    }

    .menu-btn {
      display: flex;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      margin: -0.5rem;
      min-width: 44px;
      min-height: 44px;
      align-items: center;
      justify-content: center;
    }

    .menu-btn span {
      display: block;
      width: 22px;
      height: 2px;
      background: var(--ink);
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    /* hamburger → X */
    .site-nav.open .menu-btn span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .site-nav.open .menu-btn span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .site-nav.open .menu-btn span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .nav-links,
    .nav-right {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .site-nav.open .nav-links {
      display: flex;
      margin-top: 1rem;
      padding-top: 0.25rem;
      border-top: 1px solid var(--divider);
    }

    .site-nav.open .nav-right {
      display: flex;
      border-top: 1px solid var(--divider);
      padding-bottom: 0.5rem;
    }

    .site-nav.open .nav-link {
      display: block;
      padding: 0.9rem 0;
      font-size: 1.0625rem;
      border-bottom: 1px solid var(--divider);
    }
  }
</style>

<script>
  const nav = document.getElementById('siteNav')!;
  const btn = document.getElementById('menuBtn')!;

  btn.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });

  nav.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => nav.classList.remove('open'));
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') nav.classList.remove('open');
  });
</script>
