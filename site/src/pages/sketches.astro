---
import Base from '../layouts/Base.astro';
import Lightbox from '../components/Lightbox.astro';
export const prerender = true;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sketches = [
  { file: 'Bluesboys.jpeg',                   title: 'Bluesboys' },
  { file: 'CarlosWallPainting2.jpeg',         title: 'Carlos Wall Painting' },
  { file: 'Castle.jpeg',                      title: 'Castle' },
  { file: 'Currywurststandfinal copy.jpeg',   title: 'Currywurst Stand' },
  { file: 'DuBisteinBerliner2.jpeg',          title: 'Du Bist ein Berliner' },
  { file: 'Fuckyourgas.jpeg',                 title: 'Fuck Your Gas' },
  { file: 'Klemke.jpg',                       title: 'Klemke' },
  { file: 'Litzensee2.jpeg',                  title: 'Litzensee' },
  { file: 'PotsdamRussianVillage2.jpg',       title: 'Potsdam Russian Village' },
  { file: 'Putin.jpeg',                       title: 'Putin' },
  { file: 'Tefelsberg2.jpeg',                 title: 'Tefelsberg' },
  { file: 'cargobikes.jpg',                   title: 'Cargo Bikes' },
  { file: 'castlebridge.jpeg',               title: 'Castle Bridge' },
  { file: 'killingart2.jpeg',                title: 'Killing Art' },
  { file: 'moreespresso.jpeg',               title: 'More Espresso' },
  { file: 'parking.jpeg',                    title: 'Parking' },
  { file: 'platzinsnow2.jpg',                title: 'Platz in Snow' },
  { file: 'square1.jpeg',                    title: 'Square' },
];
---

<Base title="Sketches" activeNav="sketches">
  <section class="sketches">

    <header class="sketches-header">
      <p class="meta-label">SKETCHES · SELECTED WORK</p>
      <h1 class="page-title">Sketches</h1>
    </header>

    <hr class="divider" />

    <div class="sketch-grid">
      {sketches.map((s) => (
        <article class="sketch-card">
          <div class="card-image">
            <img
              src={`${base}/2d-images/${s.file}`}
              alt={s.title}
              loading="lazy"
              data-lightbox
            />
          </div>
          <div class="card-info">
            <span class="card-title">{s.title}</span>
          </div>
        </article>
      ))}
    </div>

  </section>
  <Lightbox />
</Base>

<script>
  const grid = document.querySelector<HTMLElement>('.sketch-grid')!;
  const cards = [...grid.querySelectorAll<HTMLElement>('.sketch-card')];
  for (let i = cards.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    grid.appendChild(cards[j]);
    [cards[i], cards[j]] = [cards[j], cards[i]];
  }
</script>

<style>
  .sketches {
    margin-left: 32%;
    padding: 2.5rem 3rem 7rem 2rem;
  }

  .sketches-header {
    margin-bottom: 2.5rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--divider);
    margin-bottom: 2rem;
  }

  /* ── Grid ── */

  .sketch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 1.5rem;
    margin-top: 2rem;
  }

  /* ── Card ── */

  .sketch-card {
    display: flex;
    flex-direction: column;
  }

  .card-image {
    aspect-ratio: 3 / 4;
    background: #ECEAE0;
    margin-bottom: 0.875rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 1rem;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .card-desc {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--ink);
    opacity: 0.7;
  }

  /* ── Responsive ── */

  @media (max-width: 900px) {
    .sketches {
      margin-left: 0;
      padding: 1.5rem 1.5rem 5rem;
    }

    .sketch-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .sketch-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
