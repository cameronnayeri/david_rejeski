---
import Base from '../layouts/Base.astro';
import Lightbox from '../components/Lightbox.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sketches = [
  { num: 1,  ext: 'jpg',  title: 'Bauhaus Desk Lamp',                   desc: 'The dome-topped stool emerged from sketches exploring the tension between mass and delicacy. The walnut base grounds what the cushioned dome lifts.' },
  { num: 2,  ext: 'jpg',  title: 'Negative Space',                      desc: '' },
  { num: 3,  ext: 'jpg',  title: 'Bookcase',                            desc: 'Drawn from a long fascination with the Pagoda form, this bookcase takes the idea of shelter and applies it to books. The rendering came first — the wood followed its logic almost automatically. The final piece departs from the rendering in one key way: the shelves became lighter.' },
  { num: 4,  ext: 'jpg',  title: 'Shelf with Leveling Ball',            desc: 'Each shelf finds its level independently.' },
  { num: 5,  ext: 'jpg',  title: 'Fat Leg Table',                       desc: 'The legs are the point. Tapered cylinders in cherry, they reference classical column forms while remaining entirely contemporary in their relationship to the walnut top.' },
  { num: 6,  ext: 'jpg',  title: 'Bench',                               desc: '' },
  { num: 7,  ext: 'jpg',  title: 'Bedside Table',                       desc: 'A piece born of quitting. The thin steel legs feel like something held between two fingers. Objects for a reformed habit, made with the same precision the habit once demanded.' },
  { num: 8,  ext: 'jpg',  title: 'Side Table',                          desc: 'Oval over oval.' },
  { num: 9,  ext: 'png',  title: 'Cradle with Rocking Adjustment',      desc: 'The mechanism allows the rocker to be locked at different angles, changing the tempo of the rock. A piece that admits the parent has needs too.' },
  { num: 10, ext: 'jpg',  title: 'Pencil Holder/Sharpener',             desc: '' },
  { num: 11, ext: 'png',  title: 'Stacking Tables',                     desc: 'Stacks up.' },
  { num: 12, ext: 'jpeg', title: 'Book Stand',                          desc: 'The table top floats on wire legs that zigzag and terminate in small turned pendulums — a table that looks as if it is in the middle of deciding whether to stay still. The visual instability is the point. It sits perfectly.' },
  { num: 13, ext: 'jpg',  title: 'Table Looses Leg',                    desc: 'A root slab top on turned legs — one of which is a prosthetic. The piece started with a found leg and worked outward.' },
  { num: 14, ext: 'jpg',  title: 'Music Stand (fuer Elise)',             desc: 'For a pianist.' },
  { num: 15, ext: 'jpg',  title: '3-in-1 Bowl with Crumb Drain',        desc: 'One bowl, three functions. The sketchbook page says it all — materials called out by name, crumb drain engineered before the first cut.' },
];
---

<Base title="Sketches" activeNav="sketches">
  <section class="sketches">

    <header class="sketches-header">
      <p class="meta-label">SKETCHES · SELECTED WORK</p>
      <h1 class="page-title">Sketches</h1>
    </header>

    <hr class="divider" />

    <div class="sketch-grid">
      {sketches.map((s) => (
        <article class="sketch-card">
          <div class="card-image">
            <img
              src={`${base}/sketches+images/${s.num}a.${s.ext}`}
              alt={`${s.title} — sketch`}
              loading="lazy"
              data-lightbox
            />
          </div>
          <div class="card-info">
            <span class="card-title">{s.title}</span>
            {s.desc && <p class="card-desc">{s.desc}</p>}
          </div>
        </article>
      ))}
    </div>

  </section>
  <Lightbox />
</Base>

<style>
  .sketches {
    margin-left: 32%;
    padding: 2.5rem 3rem 7rem 2rem;
  }

  .sketches-header {
    margin-bottom: 2.5rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--divider);
    margin-bottom: 2rem;
  }

  /* ── Grid ── */

  .sketch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 1.5rem;
    margin-top: 2rem;
  }

  /* ── Card ── */

  .sketch-card {
    display: flex;
    flex-direction: column;
  }

  .card-image {
    aspect-ratio: 3 / 4;
    background: #ECEAE0;
    margin-bottom: 0.875rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 1rem;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .card-desc {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--ink);
    opacity: 0.7;
  }

  /* ── Responsive ── */

  @media (max-width: 900px) {
    .sketches {
      margin-left: 0;
      padding: 1.5rem 1.5rem 5rem;
    }

    .sketch-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .sketch-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
