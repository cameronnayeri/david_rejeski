---
import Base from '../layouts/Base.astro';
import { getSettings } from '../lib/db';
import { STUDIO_DEFAULTS } from '../lib/studio';
import { mdInline } from '../lib/markdown';
import { env } from '../lib/env';

export const prerender = false;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const saved = await getSettings(env.DB);
const t = (key: string) => mdInline(saved[key] ?? STUDIO_DEFAULTS[key] ?? '');
---

<Base title="Studio" activeNav="studio">
  <div class="studio-layout">

    <!-- ── Sticky sidebar ── -->
    <aside class="sidebar">
      <p class="meta-label">ABOUT</p>

      <img class="portrait" src={`${base}/images/studio/portrait.png`} alt="David Rejeski" />

      <p class="bio-text" set:html={t('studio_bio_1')} />

      <p class="bio-text" set:html={t('studio_bio_2')} />

      <p class="bio-text" set:html={t('studio_bio_3')} />

      <hr class="sidebar-rule" />

      <p class="contact-line">
        <a href="mailto:dave.rejeski@gmail.com">dave.rejeski@gmail.com</a>
        <span class="contact-sep">·</span>
        <a href="https://www.linkedin.com/in/david-rejeski-4a72463/" target="_blank" rel="noopener">LinkedIn</a>
      </p>

      <hr class="sidebar-rule" />

      <div class="writing-row">
        <div>
          <p class="writing-label">WRITING</p>
          <ul class="writing-list">
            <li><a href={`${base}/writing/vienna-coffeehouses.pdf`} target="_blank" rel="noopener">Vienna: Ten Coffeehouses in Ten Days</a></li>
            <li><a href={`${base}/writing/bring-back-the-worlds-fair.pdf`} target="_blank" rel="noopener">Bring Back the World's Fair</a></li>
            <li><a href={`${base}/writing/can-crafts-be-saved.pdf`} target="_blank" rel="noopener">Can Crafts Be Saved?</a></li>
            <li><a href={`${base}/writing/revolutions-in-the-making.pdf`} target="_blank" rel="noopener">Revolutions in the Making</a></li>
          </ul>
        </div>
        <img class="dave-sketch" src={`${base}/images/studio/davesketch.jpg`} alt="Sketch" />
      </div>
    </aside>

    <!-- ── Main content ── -->
    <section class="studio-main">

      <header class="studio-header">
        <p class="meta-label">THE STUDIO · WESTERN MASSACHUSETTS</p>
        <h1 class="page-title">Studio</h1>
      </header>

      <hr class="divider" />

      <p class="intro" set:html={t('studio_intro')} />

      <div class="narrative">

        <div class="full-image">
          <img src={`${base}/images/studio/barn.jpeg`} alt="The studio barn" />
        </div>

        <div class="trio">
          <div class="img-cell"><img src={`${base}/images/studio/welding.jpeg`} alt="Welding" /></div>
          <div class="img-cell"><img src={`${base}/images/studio/lathe.jpg`} alt="Lathe work" /></div>
          <div class="img-cell"><img src={`${base}/images/studio/dog.jpeg`} alt="Yoda" /></div>
        </div>

        <div class="full-image">
          <img src={`${base}/images/studio/woodbending.jpeg`} alt="Wood bending jig" />
        </div>

        <div class="potter-row">
          <div class="pot-wrap">
            <img src={`${base}/images/studio/pot.jpg`} alt="Pot by Anne Ferril" />
          </div>
          <p class="potter-text" set:html={t('studio_potter')} />
        </div>

      </div>

      <p class="site-credit">
        Site made by <a href="https://cameronnayeri.com" target="_blank" rel="noopener">Cameron Nayeri</a>
      </p>

    </section>

  </div>
</Base>

<style>
  /* ── Two-column page layout ── */

  .studio-layout {
    display: grid;
    grid-template-columns: 32% 1fr;
    min-height: calc(100vh - 5rem);
    align-items: start;
  }

  /* ── Sidebar ── */

  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    padding: 2rem 1.75rem 3rem;
    border-right: 1px solid var(--divider);
    scrollbar-width: none;
  }

  .sidebar::-webkit-scrollbar {
    display: none;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .portrait {
    width: 33%;
    height: auto;
    display: block;
    margin-bottom: 1.25rem;
    filter: grayscale(100%);
  }

  .bio-text {
    font-family: var(--font-display);
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .bio-text a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
  }

  .bio-text a:hover {
    color: var(--accent);
  }

  /* ── Sidebar rules + contact ── */

  .sidebar-rule {
    border: none;
    border-top: 1px solid var(--divider);
    margin: 1.25rem 0;
  }

  .contact-line {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .contact-sep {
    color: var(--muted);
  }

  .contact-line a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
  }

  .contact-line a:hover {
    color: var(--accent);
  }

  /* ── Writing list ── */

  .writing-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }

  .writing-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .writing-list a {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    line-height: 1.4;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.15s;
  }

  .writing-list a:hover {
    text-decoration-color: var(--accent);
  }

  .writing-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .dave-sketch {
    width: 35%;
    height: auto;
    display: block;
    flex-shrink: 0;
  }

  /* ── Main content ── */

  .studio-main {
    padding: 2.5rem 3rem 7rem 2.5rem;
  }

  .studio-header {
    margin-bottom: 2.5rem;
  }

  .studio-main .meta-label {
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--divider);
    margin-bottom: 2.5rem;
  }

  .intro {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--ink);
    max-width: 52ch;
    margin-bottom: 2rem;
  }

  /* ── Narrative ── */

  .narrative {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .full-image {
    width: 100%;
    overflow: hidden;
  }

  .full-image img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
  }

  .pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .placeholder-cell {
    background: #ECEAE0;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .full-placeholder {
    aspect-ratio: 16 / 7;
  }

  .placeholder-cell span {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    opacity: 0.45;
  }

  .trio {
    display: flex;
    gap: 0.75rem;
  }

  .img-cell {
    flex: 1 1 0;
    min-width: 0;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .img-cell:first-child {
    flex: 0.6 1 0;
  }

  .img-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
  }

  .writing-placeholder {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--muted);
    opacity: 0.5;
  }

  /* ── Potter row ── */

  .potter-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-top: 0.75rem;
  }

  .pot-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .potter-text {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
  }

  .potter-text a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
  }

  .potter-text a:hover {
    color: var(--accent);
  }

  /* ── Site credit ── */

  .site-credit {
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    opacity: 0.7;
  }

  .site-credit a {
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--divider);
  }

  .site-credit a:hover {
    color: var(--accent);
  }

  /* ── Responsive ── */

  @media (max-width: 900px) {
    .studio-layout {
      display: block;
    }

    .sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--divider);
      padding: 1.5rem;
    }

    .studio-main {
      padding: 1.5rem 1.5rem 5rem;
    }

    .potter-row {
      grid-template-columns: 120px 1fr;
      gap: 1rem;
    }
  }
</style>
