---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const allPieces = await getCollection('pieces', ({ data }) => data.status === 'published');

const pieces = allPieces.sort((a, b) => {
  const orderA = a.data.order ?? a.data.number;
  const orderB = b.data.order ?? b.data.number;
  return orderA - orderB;
});

const years = pieces.map((p) => p.data.year);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const yearRange = minYear === maxYear ? String(minYear) : `${minYear} — ${maxYear}`;

const allCategories = ['Chairs & Stools', 'Tables', 'Lamps', 'Sculpture', 'Whimsies', 'Commission'] as const;
const categoryCounts = allCategories
  .map((cat) => ({ name: cat, count: pieces.filter((p) => p.data.category === cat).length }))
  .filter((c) => c.count > 0);

const numStr = (n: number) => `No. ${String(n).padStart(2, '0')}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Projects" activeNav="projects">
  <section class="projects">

    <header class="projects-header">
      <p class="meta-label">INDEX · SELECTED WORK · {yearRange}</p>
      <h1 class="page-title">Projects</h1>
      <p class="page-subhead">Pieces in wood and steel, from sketch to room. Filter by what they do.</p>
    </header>

    <hr class="divider" />

    <nav class="filter-bar" aria-label="Filter by category">
      <span class="filter-label">VIEW</span>
      <ul class="filters">
        <li>
          <button class="filter-btn active" data-filter="all">
            All <span class="count">{pieces.length}</span>
          </button>
        </li>
        {categoryCounts.map((cat) => (
          <li>
            <button class="filter-btn" data-filter={cat.name}>
              {cat.name} <span class="count">{cat.count}</span>
            </button>
          </li>
        ))}
      </ul>
    </nav>

    <hr class="divider" />

    <div class="piece-grid">
      {pieces.map((piece) => (
        <article class="piece-card" data-category={piece.data.category}>
          <a href={`${base}/projects/${piece.slug}`}>
            <div class="card-image">
              {piece.data.images[0]
                ? <img src={`${base}${piece.data.images[0]}`} alt={piece.data.title} loading="lazy" />
                : <div class="card-placeholder" />
              }
            </div>
            <div class="card-info">
              <div class="card-title-row">
                <span class="card-title">{numStr(piece.data.number)} — {piece.data.title}</span>
                <span class="card-year">{piece.data.year}</span>
              </div>
              <p class="card-materials">
                {piece.data.materials.map((m) => m.toUpperCase()).join(' · ')}
              </p>
              <p class="card-category">{piece.data.category.toUpperCase()}</p>
            </div>
          </a>
        </article>
      ))}
    </div>

  </section>
</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.piece-card');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach((card) => {
        card.hidden = filter !== 'all' && card.dataset.category !== filter;
      });
    });
  });
</script>

<style>
  .projects {
    margin-left: 32%;
    padding: 2.5rem 3rem 7rem 2rem;
  }

  /* ── Header ──────────────────────────────────── */

  .projects-header {
    margin-bottom: 2.5rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .page-subhead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 44ch;
    opacity: 0.75;
  }

  /* ── Dividers ─────────────────────────────────── */

  .divider {
    border: none;
    border-top: 1px solid var(--divider);
  }

  /* ── Filter bar ───────────────────────────────── */

  .filter-bar {
    display: flex;
    align-items: baseline;
    padding: 0.875rem 0;
  }

  .filter-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-right: 1.75rem;
    flex-shrink: 0;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
  }

  .filter-btn {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--ink);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0;
    margin-right: 2rem;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  .filter-btn:hover {
    opacity: 0.55;
  }

  .filter-btn.active {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 1.5px;
  }

  .count {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--muted);
    font-weight: 400;
    margin-left: 0.2rem;
  }

  /* ── Card grid ────────────────────────────────── */

  .piece-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 1.5rem;
    margin-top: 2rem;
  }

  .piece-card[hidden] {
    display: none;
  }

  .piece-card a {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  /* ── Card image ───────────────────────────────── */

  .card-image {
    aspect-ratio: 3 / 4;
    background: #ECEAE0;
    margin-bottom: 0.875rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }

  .piece-card a:hover .card-image img {
    transform: scale(1.02);
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
  }

  /* ── Card info ────────────────────────────────── */

  .card-title-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .card-year {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    flex-shrink: 0;
  }

  .card-materials {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 0.3rem;
  }

  .card-category {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.12em;
    color: var(--accent);
  }

  /* ── Responsive ───────────────────────────────── */

  @media (max-width: 900px) {
    .projects {
      margin-left: 0;
      padding: 1.5rem 1.5rem 5rem;
    }

    .piece-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .piece-grid {
      grid-template-columns: 1fr;
    }

    .filter-bar {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
