---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Studio C" activeNav="studio">
  <section class="studio">

    <header class="studio-header">
      <p class="meta-label">THE STUDIO · WESTERN MASSACHUSETTS</p>
      <h1 class="page-title">Studio</h1>
    </header>

    <hr class="divider" />

    <div class="image-grid">
      <div class="cell cell--barn">
        <img src={`${base}/images/studio/barn.jpeg`} alt="The studio barn" />
      </div>
      <div class="cell cell--woodbending">
        <img src={`${base}/images/studio/woodbending.jpeg`} alt="Wood bending jig" />
      </div>
      <div class="cell cell--placeholder"><span>GUITAR CARVING</span></div>
      <div class="cell cell--placeholder"><span>WELDING</span></div>
      <div class="cell cell--placeholder"><span>TOOLS</span></div>
      <div class="cell cell--placeholder"><span>VENEER STRIPS</span></div>
      <div class="cell cell--placeholder"><span>LOOM</span></div>
      <div class="cell cell--pot">
        <img src={`${base}/images/studio/pot.jpg`} alt="Pot by Anne Ferril" />
      </div>
    </div>

    <div class="text-block">
      <p>I work in an old gambrel roofed barn built in the late 19th century located in Western Massachusetts.</p>
      <p>I give wood shavings to a great potter, <a href="https://www.berkshirepotterscollective.org/aferril" target="_blank" rel="noopener">Anne Ferril</a>, who uses them to fire her pots: artistic recycling.</p>
    </div>

  </section>
</Base>

<style>
  .studio {
    margin-left: 32%;
    padding: 2.5rem 3rem 7rem 2rem;
  }

  .studio-header {
    margin-bottom: 2.5rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--divider);
    margin-bottom: 2.5rem;
  }

  /* ── Photo grid (3-col masonry) ── */

  .image-grid {
    columns: 3;
    column-gap: 0.75rem;
  }

  .cell {
    break-inside: avoid;
    margin-bottom: 0.75rem;
    background: #ECEAE0;
    overflow: hidden;
  }

  .cell img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
  }

  .cell--pot img {
    filter: none;
    object-fit: contain;
  }

  .cell--placeholder {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cell--placeholder span {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    opacity: 0.45;
  }

  /* ── Text block below grid ── */

  .text-block {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    border-top: 1px solid var(--divider);
    padding-top: 2rem;
  }

  .text-block p {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
  }

  .text-block a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .text-block a:hover {
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .studio {
      margin-left: 0;
      padding: 1.5rem 1.5rem 5rem;
    }

    .image-grid {
      columns: 2;
    }

    .text-block {
      grid-template-columns: 1fr;
    }
  }
</style>
