---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import PieceDetail from '../components/PieceDetail.astro';

const piece = await getEntry('pieces', 'bench');
---

<Base title={`B — ${piece.data.title}`} activeNav="projects">
  <PieceDetail data={piece.data} imageLayout="masonry-3" />
</Base>
