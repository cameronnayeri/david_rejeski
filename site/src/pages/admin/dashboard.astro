---
import Admin from '../../layouts/Admin.astro';
import { listProjects } from '../../lib/db';
import { env } from '../../lib/env';

export const prerender = false;

const projects = await listProjects(env.DB);
---

<Admin title="Dashboard" showNav>
  <div class="head">
    <h1>Projects <span class="count">{projects.length}</span></h1>
    <a href="/admin/projects/new" class="btn">+ New project</a>
  </div>

  {projects.length === 0 ? (
    <p class="empty">No projects yet. Create your first one.</p>
  ) : (
    <ul class="proj-list">
      {projects.map((p) => (
        <li class="proj-row">
          <a class="thumb" href={`/admin/projects/${p.id}`}>
            {p.images[0]
              ? <img src={p.images[0]} alt="" loading="lazy" />
              : <span class="thumb-empty">—</span>}
          </a>
          <a class="proj-main" href={`/admin/projects/${p.id}`}>
            <span class="proj-title">{p.title}</span>
            <span class="proj-meta">{p.category}{p.year ? ` · ${p.year}` : ''}</span>
          </a>
          <span class={`badge badge-${p.status}`}>{p.status}</span>
          {p.featured && <span class="badge badge-featured">featured</span>}
          <div class="proj-actions">
            <a href={`/admin/projects/${p.id}`} class="admin-link">Edit</a>
            <button class="admin-link del" data-id={p.id} data-title={p.title}>Delete</button>
          </div>
        </li>
      ))}
    </ul>
  )}
</Admin>

<style>
  .head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .head h1 { font-size: 1.6rem; }
  .count { font-size: 1rem; color: var(--muted); font-weight: 400; }
  .empty { color: var(--muted); padding: 2rem 0; }
  .proj-list { list-style: none; }
  .proj-row {
    display: flex; align-items: center; gap: 1rem; padding: 0.7rem 0;
    border-bottom: 1px solid var(--divider);
  }
  .thumb {
    width: 52px; height: 52px; flex-shrink: 0; border-radius: 6px; overflow: hidden;
    background: #ECEAE0; display: flex; align-items: center; justify-content: center;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb-empty { color: var(--muted); }
  .proj-main { flex: 1; display: flex; flex-direction: column; text-decoration: none; min-width: 0; }
  .proj-title { font-weight: 600; }
  .proj-meta { font-size: 0.8rem; color: var(--muted); }
  .badge {
    font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 999px; text-transform: uppercase;
    letter-spacing: 0.04em; font-weight: 600;
  }
  .badge-published { background: #d7f0dd; color: #0f5132; }
  .badge-draft { background: #fdf0d5; color: #8a6d3b; }
  .badge-archived { background: #e6e2d6; color: #6b6452; }
  .badge-featured { background: var(--accent); color: #fff; }
  .proj-actions { display: flex; gap: 0.9rem; }
  .del { color: var(--accent); }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.del').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      if (!confirm(`Delete "${btn.dataset.title}"? This cannot be undone.`)) return;
      const res = await fetch(`/api/projects/${id}`, { method: 'DELETE' });
      if (res.ok) btn.closest('.proj-row')?.remove();
      else alert('Delete failed.');
    });
  });
</script>
