---
import Admin from '../../layouts/Admin.astro';
import { listProjects, listSketches } from '../../lib/db';
import { env } from '../../lib/env';

export const prerender = false;

interface Usage { label: string; href: string }

const [listed, projects, sketches] = await Promise.all([
  env.MEDIA.list({ limit: 1000 }),
  listProjects(env.DB),
  listSketches(env.DB),
]);

// Map each image URL to the places that use it.
const usage = new Map<string, Usage[]>();
const add = (url: string, u: Usage) => {
  const arr = usage.get(url) ?? [];
  arr.push(u);
  usage.set(url, arr);
};
for (const p of projects) {
  for (const img of p.images) add(img, { label: `Project: ${p.title}`, href: `/projects/${p.slug}` });
}
for (const s of sketches) {
  if (s.image) add(s.image, { label: `Sketch: ${s.title}`, href: `/sketches` });
}

const images = listed.objects
  .sort((a, b) => (a.uploaded < b.uploaded ? 1 : -1))
  .map((o) => {
    const url = `/img/${o.key}`;
    return { key: o.key, url, usedBy: usage.get(url) ?? [] };
  });

const usedCount = images.filter((i) => i.usedBy.length > 0).length;
const freeCount = images.length - usedCount;
---

<Admin title="Media library" showNav section="media">
  <div class="head">
    <h1>Media library <span class="count">{images.length}</span></h1>
    <p class="summary">{usedCount} in use · {freeCount} unused</p>
  </div>
  <p class="lede">Only images not used on any page can be deleted.</p>

  <div class="media-grid">
    {images.map((img) => (
      <figure class="media-card" data-key={img.key}>
        <div class="media-thumb">
          <img src={img.url} alt="" loading="lazy" />
        </div>
        <figcaption class="media-info">
          {img.usedBy.length > 0 ? (
            <ul class="usage">
              {img.usedBy.map((u) => (
                <li><a href={u.href} target="_blank" rel="noopener">{u.label}</a></li>
              ))}
            </ul>
          ) : (
            <span class="unused">Not used</span>
          )}
        </figcaption>
        {img.usedBy.length === 0 && (
          <button class="btn-trash media-del" data-key={img.key} aria-label="Delete image" title="Delete">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2m2 0v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
          </button>
        )}
      </figure>
    ))}
  </div>
</Admin>

<style>
  .head { display: flex; align-items: baseline; justify-content: space-between; }
  .head h1 { font-size: 1.6rem; }
  .count { font-size: 1rem; color: var(--muted); font-weight: 400; }
  .summary { font-size: 0.85rem; color: var(--muted); }
  .lede { color: var(--muted); font-size: 0.9rem; margin: 0.25rem 0 1.5rem; }

  .media-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem;
  }
  .media-card {
    position: relative; border: 1px solid var(--divider); border-radius: 8px;
    overflow: hidden; background: var(--field); display: flex; flex-direction: column;
  }
  .media-thumb { height: 130px; background: #ECEAE0; }
  .media-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .media-info { padding: 0.6rem 0.7rem; font-size: 0.75rem; }
  .usage { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; }
  .usage a { color: var(--ink); text-decoration: none; }
  .usage a:hover { color: var(--accent); text-decoration: underline; }
  .unused { color: var(--muted); font-style: italic; }
  .media-del {
    position: absolute; top: 6px; right: 6px; background: rgba(255,255,255,0.9);
  }
  .media-del:hover { background: #fff; }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.media-del').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.key!;
      if (!confirm('Delete this unused image? This cannot be undone.')) return;
      const res = await fetch(`/api/media/${key}`, { method: 'DELETE' });
      if (res.ok) {
        btn.closest('.media-card')?.remove();
      } else {
        const data = await res.json().catch(() => ({}));
        alert(data.error || 'Delete failed.');
      }
    });
  });
</script>
