---
import Admin from '../../layouts/Admin.astro';
export const prerender = false;
---

<Admin title="Recover password">
  <div class="auth-card">
    <h1>Reset password</h1>
    <p class="lede">
      Enter the recovery key (kept by the site developer) to set a new password
      for an account. Unknown emails create a new admin.
    </p>
    <div id="msg" class="msg" hidden></div>
    <form id="recover-form">
      <div class="field">
        <label for="recovery_key">Recovery key</label>
        <input type="password" id="recovery_key" name="recovery_key" required />
      </div>
      <div class="field">
        <label for="email">Account email</label>
        <input type="email" id="email" name="email" required autocomplete="username" />
      </div>
      <div class="field">
        <label for="password">New password</label>
        <input type="password" id="password" name="password" required minlength="8" autocomplete="new-password" />
        <p class="hint">At least 8 characters.</p>
      </div>
      <button type="submit" class="btn" style="width:100%">Set password</button>
    </form>
    <p class="auth-foot"><a href="/admin">Back to sign in</a></p>
  </div>
</Admin>

<style>
  .auth-card { max-width: 360px; margin: 4rem auto 0; }
  .auth-card h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
  .lede { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.5rem; }
  .auth-foot { margin-top: 1rem; font-size: 0.8rem; }
</style>

<script>
  const form = document.getElementById('recover-form') as HTMLFormElement;
  const msg = document.getElementById('msg')!;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    msg.hidden = true;
    const res = await fetch('/api/auth/recover', { method: 'POST', body: new FormData(form) });
    const data = await res.json();
    if (data.ok) {
      msg.className = 'msg msg-ok';
      msg.textContent = 'Password set. You can now sign in.';
      msg.hidden = false;
      form.reset();
    } else {
      msg.className = 'msg msg-error';
      msg.textContent = data.error || 'Recovery failed.';
      msg.hidden = false;
    }
  });
</script>
