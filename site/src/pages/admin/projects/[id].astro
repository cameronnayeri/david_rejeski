---
import Admin from '../../../layouts/Admin.astro';
import ProjectForm from '../../../components/ProjectForm.astro';
import { getProject } from '../../../lib/db';
import { env } from '../../../lib/env';

export const prerender = false;

const id = Number(Astro.params.id);
const project = Number.isInteger(id) ? await getProject(env.DB, id) : null;
if (!project) return Astro.redirect('/admin/dashboard');
---

<Admin title={`Edit · ${project.title}`} showNav>
  <p class="crumb"><a href="/admin/dashboard">← Projects</a></p>
  <h1>Edit project</h1>
  <ProjectForm project={project} />
</Admin>

<style>
  .crumb { font-size: 0.8rem; margin-bottom: 1rem; }
  .crumb a { color: var(--muted); text-decoration: none; }
  h1 { font-size: 1.6rem; margin-bottom: 1.5rem; }
</style>
