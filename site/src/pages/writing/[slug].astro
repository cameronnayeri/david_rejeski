---
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  return [
    {
      params: { slug: 'vienna-coffeehouses' },
      props: { title: 'Vienna: Ten Coffeehouses in Ten Days', src: '/writing/vienna-coffeehouses.pdf' },
    },
    {
      params: { slug: 'bring-back-the-worlds-fair' },
      props: {
        title: "Bring Back the World's Fair",
        src: 'https://docs.google.com/viewer?url=https%3A%2F%2Fdavidrejeski.com%2Fwriting%2Fbring-back-the-worlds-fair.doc&embedded=true',
      },
    },
    {
      params: { slug: 'can-crafts-be-saved' },
      props: { title: 'Can Crafts Be Saved?', src: '/writing/can-crafts-be-saved.pdf' },
    },
    {
      params: { slug: 'revolutions-in-the-making' },
      props: { title: 'Revolutions in the Making', src: '/writing/revolutions-in-the-making.pdf' },
    },
  ];
}

const { title, src } = Astro.props;
---

<Base title={title}>
  <div class="writing-page">
    <header class="writing-header">
      <p class="meta-label">WRITING · DAVID REJESKI</p>
      <h1 class="page-title">{title}</h1>
    </header>
    <div class="viewer-wrap">
      <iframe src={src} title={title}></iframe>
    </div>
  </div>
</Base>

<style>
  .writing-page {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 5rem);
    padding: 2rem 3rem 0;
  }

  .writing-header {
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .viewer-wrap {
    flex: 1;
    min-height: 0;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  @media (max-width: 900px) {
    .writing-page {
      padding: 1.5rem 1.5rem 0;
    }
  }
</style>
