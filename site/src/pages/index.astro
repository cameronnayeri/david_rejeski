---
import Base from '../layouts/Base.astro';
export const prerender = true;
---

<Base title="David Rejeski" activeNav="home">
  <div class="home">
    <div class="logomark">
      <div class="logo-row">
        <span class="logo-text">2D</span>
        <span class="logo-bar"></span>
        <span class="logo-text">3D</span>
      </div>
      <p class="logo-sub">
        <span class="sub-side">FURNITURE&nbsp;·</span>
        <span>SCULPTURE</span>
        <span class="sub-side sub-right">·&nbsp;DESIGN</span>
      </p>
    </div>
  </div>
</Base>

<style>
  .home {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 5.25rem);
  }

  .logomark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .logo-row {
    display: flex;
    align-items: center;
    font-size: clamp(3rem, 13vw, 11rem);
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1em;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
  }

  .logo-bar {
    display: block;
    width: clamp(12px, 1.1vw, 20px);
    height: 1.35em;
    background: var(--accent);
    flex-shrink: 0;
    margin: 0 0.18em;
  }

  .logo-sub {
    font-family: var(--font-mono);
    font-size: clamp(0.6rem, 1vw, 0.8125rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--accent);
    display: inline-grid;
    grid-template-columns: 1fr auto 1fr;
    column-gap: 0.5em;
  }

  .sub-side {
    text-align: right;
  }

  .sub-right {
    text-align: left;
  }
</style>
