---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import PieceDetail from '../components/PieceDetail.astro';

const piece = await getEntry('pieces', 'fat-leg-table');
---

<Base title={`A — ${piece.data.title}`} activeNav="projects">
  <PieceDetail data={piece.data} imageLayout="grid" />
</Base>
