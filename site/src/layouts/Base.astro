---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  activeNav?: 'home' | 'projects' | 'sketch-object';
}

const { title, activeNav } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="David Rejeski — Furniture, Sculpture, Design" />
    <title>{title} — David Rejeski</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono&family=Inter:wght@400;700;900&family=Playfair+Display:ital@1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav active={activeNav} />
    <main>
      <slot />
    </main>
  </body>
</html>
