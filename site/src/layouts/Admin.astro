---
export interface Props {
  title: string;
  showNav?: boolean;
  section?: 'projects' | 'sketches' | 'studio';
}
const { title, showNav = false, section } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>{title} — Admin</title>
  </head>
  <body>
    {showNav && (
      <header class="admin-bar">
        <a href="/admin/dashboard" class="admin-brand">David Rejeski · Admin Panel</a>
        <div class="admin-bar-right">
          <a href="/" class="admin-link" target="_blank" rel="noopener">View site ↗</a>
          {user && <span class="admin-user">{user.email}</span>}
          <form method="POST" action="/api/auth/logout" class="logout-form">
            <button type="submit" class="admin-link">Log out</button>
          </form>
        </div>
      </header>
    )}
    {showNav && section && (
      <nav class="admin-tabs">
        <a href="/admin/dashboard" class:list={['admin-tab', { active: section === 'projects' }]}>Projects</a>
        <a href="/admin/sketches" class:list={['admin-tab', { active: section === 'sketches' }]}>Sketches</a>
        <a href="/admin/studio" class:list={['admin-tab', { active: section === 'studio' }]}>Studio</a>
      </nav>
    )}
    <main class="admin-main">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg: #F2EFE3;
    --ink: #1A1A1A;
    --accent: #C5532A;
    --muted: #7A7060;
    --divider: #D9D4C5;
    --field: #FBFAF5;
    --font: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --font-mono: ui-monospace, 'SF Mono', Menlo, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--ink); font-family: var(--font); line-height: 1.5; }
  a { color: inherit; }

  .admin-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.5rem; border-bottom: 1px solid var(--divider); background: var(--field);
    position: sticky; top: 0; z-index: 10;
  }
  .admin-brand { font-weight: 700; text-decoration: none; }
  .admin-bar-right { display: flex; align-items: center; gap: 1.25rem; }
  .admin-user { font-size: 0.8rem; color: var(--muted); }
  .admin-link {
    font: inherit; font-size: 0.85rem; background: none; border: none; cursor: pointer;
    color: var(--ink); text-decoration: none; padding: 0;
  }
  .admin-link:hover { color: var(--accent); }
  .logout-form { display: inline; }

  .admin-tabs {
    display: flex; gap: 1.5rem; padding: 0 1.5rem; border-bottom: 1px solid var(--divider);
    background: var(--field);
  }
  .admin-tab {
    padding: 0.75rem 0; font-size: 0.9rem; font-weight: 600; text-decoration: none;
    color: var(--muted); border-bottom: 2px solid transparent; margin-bottom: -1px;
  }
  .admin-tab:hover { color: var(--ink); }
  .admin-tab.active { color: var(--ink); border-bottom-color: var(--accent); }
  .admin-main { max-width: 880px; margin: 0 auto; padding: 2rem 1.5rem 5rem; }

  /* ── Forms ──────────────────────────────────── */
  .field { margin-bottom: 1.25rem; }
  .field label { display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.4rem; }
  .field .hint { font-size: 0.75rem; color: var(--muted); margin-top: 0.3rem; }
  input[type="text"], input[type="number"], input[type="email"],
  input[type="password"], select, textarea {
    width: 100%; font: inherit; font-size: 0.95rem; padding: 0.6rem 0.7rem;
    background: var(--field); border: 1px solid var(--divider); border-radius: 6px; color: var(--ink);
  }
  textarea { resize: vertical; min-height: 5rem; }
  input:focus, select:focus, textarea:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  .row { display: flex; gap: 1rem; flex-wrap: wrap; }
  .row > .field { flex: 1; min-width: 140px; }

  .btn {
    font: inherit; font-size: 0.9rem; font-weight: 600; cursor: pointer;
    padding: 0.6rem 1.1rem; border-radius: 6px; border: 1px solid var(--ink);
    background: var(--ink); color: var(--bg); text-decoration: none; display: inline-block;
  }
  .btn:hover { opacity: 0.85; }
  .btn-secondary { background: transparent; color: var(--ink); }
  .btn-danger { background: var(--accent); border-color: var(--accent); color: #fff; }
  .btn:disabled { opacity: 0.5; cursor: default; }

  .btn-trash {
    display: inline-flex; align-items: center; justify-content: center;
    background: none; border: none; cursor: pointer; color: var(--accent);
    padding: 0.35rem; border-radius: 6px; line-height: 0;
  }
  .btn-trash:hover { background: rgba(197, 83, 42, 0.12); }
  .btn-trash svg { display: block; }

  .msg { padding: 0.7rem 0.9rem; border-radius: 6px; font-size: 0.85rem; margin-bottom: 1rem; }
  .msg-error { background: #f8d7d7; color: #842029; }
  .msg-ok { background: #d7f0dd; color: #0f5132; }
</style>
